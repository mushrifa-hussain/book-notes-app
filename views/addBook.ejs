<%- include("partials/header.ejs") %>

<div class="addBook">
    <h1><%= locals.book ? "Edit the book detail" : "Enter the book details" %>s</h1>
    <% if(locals.book){ %>
        <form action="/edit" method="POST">
            <input type="hidden" name="id" value="<%= book.id %>">
            <input type="text" name="title" placeholder="Title" value="<%= book.title %>">
            <input type="number" name="rating" id="" placeholder="Rate out of 10" value="<%= book.rating %>">
            <textarea type="text" name="notes" id="note" placeholder="Note"><%= book.notes %></textarea>
            <input type="date" name="date" value="<%= book.date %>">
            <p style="color: brown;"><%= locals.error ? locals.error : ""%></p>
            <button type="submit">Submit</button>
        </form>
    <% }else{ %>
        <form action="/add" method="POST">
            <input type="text" name="title" placeholder="Title">
            <input type="number" name="rating" id="" placeholder="Rate out of 10">
            <textarea type="text" name="notes" id="note" placeholder="Note"></textarea>
            <input type="date" name="date">
            <p style="color: brown;"><%= locals.error ? error : ""%></p>
            <button type="submit">Submit</button>
        </form>
    <% } %>
</div>


<%- include("partials/footer.ejs") %>